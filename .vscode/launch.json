{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug Prisma (CLI Build)",
            "program": "${workspaceFolder}/.xcode-build/Build/Products/Debug/Prisma.app/Contents/MacOS/Prisma",
            "args": [],
            "cwd": "${workspaceFolder}",
            "env": {
                "OS_ACTIVITY_MODE": "disable"
            },
            "preLaunchTask": "build-debug",
            "sourceLanguages": [
                "swift"
            ]
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug Prisma (No Build)",
            "program": "${workspaceFolder}/.xcode-build/Build/Products/Debug/Prisma.app/Contents/MacOS/Prisma",
            "args": [],
            "cwd": "${workspaceFolder}",
            "env": {
                "OS_ACTIVITY_MODE": "disable"
            },
            "sourceLanguages": [
                "swift"
            ]
        },
        {
            "type": "swift",
            "request": "launch",
            "args": [],
            "cwd": "${workspaceFolder:my-meeting-assistant}/MeetingAssistant",
            "name": "Debug Prisma (MeetingAssistant target)",
            "preLaunchTask": "swift: Build Debug MeetingAssistant (MeetingAssistant)",
            "target": "MeetingAssistant",
            "configuration": "debug"
        },
        {
            "type": "swift",
            "request": "launch",
            "args": [],
            "cwd": "${workspaceFolder:my-meeting-assistant}/MeetingAssistant",
            "name": "Release Prisma (MeetingAssistant target)",
            "preLaunchTask": "swift: Build Release MeetingAssistant (MeetingAssistant)",
            "target": "MeetingAssistant",
            "configuration": "release"
        }
    ]
}
