# MARK: - Project Configuration
--swiftversion 6.0

# MARK: - File Management
# Exclude build artifacts and generated code only. 
# RECOMMENDED: Do NOT exclude Tests folder manually; allow formatter to keep tests clean.
--exclude .build,DerivedData,.swiftpm,dist,**/GeneratedMocks.swift,**/Generated/**

# MARK: - Code Style (Clean Code)
# Indentation
--indent 4
--allman false
--indentcase false
--ifdef noindent

# Semicolons & Commas
--semicolons never
--commas always
--trimwhitespace always

# Self Usage (KISS - Only explicit when mandatory)
--self remove

# Functions & Closures
--wraparguments before-first
--wrapcollections before-first
--stripunusedargs closure-only
--patternlet hoist
--operatorfunc spaced
--empty void

# MARK: - Numeric Readability (Improved)
# Decimal: 1,000,000 (Standard) instead of 1,000,00 (Current 3,5)
--decimalgrouping 3,6
--binarygrouping 4,8
--hexgrouping 4,8
--octalgrouping 4,8
--fractiongrouping enabled
--exponentgrouping disabled
--exponentcase lowercase
--hexliteralcase lowercase

# MARK: - Syntax adjustments
--elseposition same-line
--ranges nospace
--linebreaks lf