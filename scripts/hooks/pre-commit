#!/bin/bash
# MARK: - Pre-commit Hook for MeetingAssistant (Optimized)
# Applies staged Swift format/lint fixes, then fails closed on residual issues.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
DAILY_BUMP_SCRIPT="${PROJECT_ROOT}/scripts/hooks/first-commit-version-bump.sh"

cd "${PROJECT_ROOT}"

# GUI clients may provide a reduced PATH that does not include Homebrew's bin
# directory. Resolve the installed tools explicitly so the hook behaves the
# same from a terminal and from a desktop Git client.
find_tool() {
    local tool="$1"

    if command -v "${tool}" &> /dev/null; then
        command -v "${tool}"
        return 0
    fi

    for candidate in \
        "/opt/homebrew/bin/${tool}" \
        "/usr/local/bin/${tool}"; do
        if [ -x "${candidate}" ]; then
            echo "${candidate}"
            return 0
        fi
    done

    return 1
}

# Auto-bump version on the first commit of the day.
if [ -x "${DAILY_BUMP_SCRIPT}" ]; then
    "${DAILY_BUMP_SCRIPT}"
fi

echo "🔍 Running pre-commit checks (staged files only)..."
echo ""

# Get staged Swift files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.swift$' || true)

if [ -z "$STAGED_FILES" ]; then
    echo "ℹ️  No Swift files staged for commit."
    echo ""
    echo "🎉 Pre-commit checks passed!"
    exit 0
fi

# Lint/format checks run by default. Set SKIP_LINT=1 to bypass.
if [ "${SKIP_LINT}" = "1" ]; then
    echo "ℹ️  Lint/format checks skipped via SKIP_LINT=1."
    echo ""
    echo "🎉 Pre-commit checks passed!"
    exit 0
fi

# Required tools are part of the staged Swift gate.
SWIFTFORMAT="$(find_tool swiftformat || true)"
if [ -z "${SWIFTFORMAT}" ]; then
    echo "❌ SwiftFormat is required for staged Swift checks. Install with: brew install swiftformat"
    exit 1
fi

SWIFTLINT="$(find_tool swiftlint || true)"
if [ -z "${SWIFTLINT}" ]; then
    echo "❌ SwiftLint is required for staged Swift checks. Install with: brew install swiftlint"
    exit 1
fi

# Count staged files
FILE_COUNT=$(echo "$STAGED_FILES" | wc -l | xargs)
echo "   Found $FILE_COUNT staged Swift file(s)"
echo ""

# 1. Apply SwiftFormat (write mode on staged files only)
echo "1️⃣  Applying SwiftFormat to staged files..."
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        "${SWIFTFORMAT}" --config .swiftformat "$file"
    fi
done
echo "   ✅ SwiftFormat applied"

# 2. Apply SwiftLint autofix (staged files only)
echo "2️⃣  Applying SwiftLint autofix to staged files..."
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        "${SWIFTLINT}" lint --config .swiftlint.yml --fix --quiet "$file" 2>/dev/null || true
    fi
done
echo "   ✅ SwiftLint autofix applied"

# 3. Re-stage formatted paths so fixes are included in the commit
echo "3️⃣  Re-staging formatted Swift files..."
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        git add -- "$file"
    fi
done
echo "   ✅ Staged index updated"
echo ""

# 4. Fail closed on residual non-autofixable issues
echo "4️⃣  Verifying formatting..."
FORMAT_FAILED=0
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        if ! "${SWIFTFORMAT}" --lint --config .swiftformat "$file" 2>/dev/null; then
            FORMAT_FAILED=1
        fi
    fi
done

if [ $FORMAT_FAILED -eq 1 ]; then
    echo "❌ Code formatting issues remain after autofix. Fix manually before committing."
    exit 1
else
    echo "   ✅ Formatting OK"
fi

echo "5️⃣  Verifying SwiftLint..."
LINT_FAILED=0
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        if ! "${SWIFTLINT}" lint --config .swiftlint.yml --quiet "$file" 2>/dev/null; then
            LINT_FAILED=1
        fi
    fi
done

if [ $LINT_FAILED -eq 1 ]; then
    echo "❌ SwiftLint violations remain after autofix. Fix manually before committing."
    exit 1
else
    echo "   ✅ SwiftLint OK"
fi

echo ""
echo "🎉 All pre-commit checks passed!"
echo ""
echo "💡 Tip: Run end-of-task module validation before push; pre-push is light unless auto=Full"
echo ""
